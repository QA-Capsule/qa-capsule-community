# Copy to .env and adjust for docker compose.
# Never commit real secrets — this file is a template only.

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret for the web UI session. Required in production.
QACAPSULE_JWT_SECRET=change-me-before-production

# ── MCP Server ────────────────────────────────────────────────────────────────
# Auth token for POST /mcp (used by Cursor, Copilot, or any MCP client).
# Generate with: openssl rand -hex 32
# Send as: Authorization: Bearer <token>  or  X-MCP-Token: <token>
# Leave empty in local dev (no auth enforced).
QACAPSULE_MCP_TOKEN=

# ── Self-Healing PRs ─────────────────────────────────────────────────────────
# GitHub token for create_remediation_pr MCP tool.
# Needs: repo (read + write) permission.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=
