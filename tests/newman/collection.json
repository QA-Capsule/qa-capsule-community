{
  "info": {
    "name": "QA Capsule — Reqres API Demo",
    "_postman_id": "qa-capsule-reqres-demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Live HTTP checks against reqres.in. The 'Contract drift' folder fails on purpose for QA Capsule ingest and MCP healing demos."
  },
  "item": [
    {
      "name": "Users API",
      "item": [
        {
          "name": "GET users page 1 returns 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('Body has data array', () => { const b = pm.response.json(); pm.expect(b.data).to.be.an('array').that.is.not.empty; });"
          ]}}],
          "request": { "method": "GET", "url": "https://reqres.in/api/users?page=1" }
        },
        {
          "name": "GET user 2 returns profile",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('User id is 2', () => pm.expect(pm.response.json().data.id).to.equal(2));"
          ]}}],
          "request": { "method": "GET", "url": "https://reqres.in/api/users/2" }
        },
        {
          "name": "POST create user returns 201",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status is 201', () => pm.response.to.have.status(201));",
            "pm.test('Name echoed', () => pm.expect(pm.response.json().name).to.equal('QA Capsule'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\": \"QA Capsule\", \"job\": \"SRE Engineer\"}" },
            "url": "https://reqres.in/api/users"
          }
        }
      ]
    },
    {
      "name": "Contract drift (intentional failures)",
      "item": [
        {
          "name": "GET missing user expects 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status is 200 (stale client contract)', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "https://reqres.in/api/users/23" }
        },
        {
          "name": "User list must contain 100 items",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Page has 100 users', () => pm.expect(pm.response.json().data).to.have.lengthOf(100));"
          ]}}],
          "request": { "method": "GET", "url": "https://reqres.in/api/users?page=1" }
        },
        {
          "name": "Response time under 50ms",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Latency SLA 50ms', () => pm.expect(pm.response.responseTime).to.be.below(50));"
          ]}}],
          "request": { "method": "GET", "url": "https://reqres.in/api/users/1" }
        }
      ]
    }
  ]
}
